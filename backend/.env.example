# Server Config
PORT=5000
NODE_ENV=development

# PostgreSQL Database (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blueprint_advisor?schema=public"

# Security (JWT Auth)
JWT_ACCESS_SECRET="super_secret_access_token_key_123"
JWT_REFRESH_SECRET="super_secret_refresh_token_key_987"

# Razorpay Payments Gateway (Mock mode enabled by default)
RAZORPAY_KEY_ID="rzp_test_mockkey"
RAZORPAY_KEY_SECRET="mock_secret_key"

# Storage Service (S3/Cloudflare R2 - Mock mode enabled if blank)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="blueprint-advisor-documents"
AWS_REGION="ap-south-1"

# FCM Push Notifications
FCM_SERVER_KEY=""

# Supabase (Storage + Realtime)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
